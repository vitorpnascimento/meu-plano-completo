# Firebase Realtime Database
# Copie este arquivo para .env.local e preencha com seus dados do Firebase Console

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=meu-plano-completo.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://meu-plano-completo-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=meu-plano-completo
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=meu-plano-completo.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# No Vercel: adicione essas variáveis em Settings > Environment Variables
